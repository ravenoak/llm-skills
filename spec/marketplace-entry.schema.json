{
  "$id": "https://github.com/ravenoak/llm-skills/spec/marketplace-entry.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "marketplace.json entry",
  "description": "A Claude Code marketplace plugin entry. Repo-level marketplace.json lives at .claude-plugin/marketplace.json and lists one or more entries of this shape under `plugins`.",
  "type": "object",
  "required": ["name", "description", "version", "source"],
  "additionalProperties": false,
  "properties": {
    "name":        { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
    "description": { "type": "string", "minLength": 10, "maxLength": 1024 },
    "version":     { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$" },
    "source":      { "type": "string", "minLength": 1 },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name":  { "type": "string", "minLength": 1 },
        "email": { "type": "string" },
        "url":   { "type": "string" }
      }
    },
    "homepage":   { "type": "string" },
    "repository": { "type": "string" },
    "license":    { "type": "string" },
    "keywords":   { "type": "array", "items": { "type": "string" } },
    "category":   { "type": "string" }
  }
}
